# Required: your VPS public IP address
SERVER_PUBLIC_IP=203.0.113.1

# WireGuard port (default 51820)
WG_PORT=51820

# VPN subnet (default 10.66.66.0/24)
WG_SUBNET=10.66.66.0/24

# API bearer token (generate with: openssl rand -hex 32)
API_TOKEN=your-secret-token-here

# API port (default 8443)
API_PORT=8443
